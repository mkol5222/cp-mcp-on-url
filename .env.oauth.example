# =============================================================================
# Check Point Management Authentication
# =============================================================================
# Choose ONE of the two options below:
#
# OPTION 1: Smart-1 Cloud (S1C) - set API_KEY and S1C_URL
# OPTION 2: Local Management   - leave S1C_URL empty, set MANAGEMENT_HOST/USERNAME/PASSWORD
# =============================================================================

# --- Option 1: Smart-1 Cloud (S1C) credentials ---
# Uncomment and fill in to use S1C instead of local management
# API_KEY=your_api_key_here
# S1C_URL=https://your-tenant.maas.checkpoint.com/your-uuid/web_api/
# Explicitly empty so docker compose doesn't pick up encrypted values from the base .env
API_KEY=
S1C_URL=

# --- Option 2: Local Management Server (used when S1C_URL is empty) ---
# Defaults are provided - override as needed
MANAGEMENT_HOST=cpman.duckdns.org
USERNAME=admin
PASSWORD=demo123

# =============================================================================
# Proxy Authentication
# =============================================================================
# API key for MCP clients (still works alongside OAuth)
PROXY_API_KEY=change-me

# Pocket ID configuration
# Public URL where Pocket ID is accessible (your cloudflared tunnel URL for Pocket ID)
POCKET_ID_URL=https://your-pocketid-tunnel.example.com
# Static API key for admin operations (generate: openssl rand -hex 32)
POCKET_ID_STATIC_API_KEY=change-me-generate-with-openssl
# Encryption key for Pocket ID v2 (min 16 bytes — generate: openssl rand -hex 32)
POCKET_ID_ENCRYPTION_KEY=change-me-generate-with-openssl

# OIDC client credentials (create in Pocket ID admin UI after setup)
OIDC_CLIENT_ID=your-oidc-client-id
OIDC_CLIENT_SECRET=your-oidc-client-secret

# OAuth2-proxy settings
# Cookie encryption secret (generate: openssl rand -base64 32 | tr -d '\n')
OAUTH2_COOKIE_SECRET=change-me-generate-32-bytes
# Callback URL for OAuth (your cloudflared tunnel URL + /oauth2/callback)
OAUTH2_REDIRECT_URL=https://your-mcp-tunnel.example.com/oauth2/callback
