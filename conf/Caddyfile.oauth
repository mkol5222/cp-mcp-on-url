:8080 {
	log {
		output stdout
		format console
	}

	# API key auth for MCP clients (bypass OAuth entirely)
	@has_api_key header X-Api-Key {env.PROXY_API_KEY}

	# Browser users with no session cookie, no Bearer token, and no API key.
	# Excludes /.well-known/*, /oauth/*, and MCP API paths.
	@needs_login {
		not header X-Api-Key *
		not header Authorization *
		not path /oauth2/*
		not path /oauth/*
		not path /.well-known/*
		not path /quantum/mcp /logs/mcp
		not header_regexp Cookie _oauth2_proxy
	}

	# MCP endpoints hit by a client that has no auth at all.
	# Return 401 + WWW-Authenticate so the client can discover OAuth.
	@mcp_unauthenticated {
		path /quantum/mcp /logs/mcp
		not header X-Api-Key *
		not header Authorization *
		not header_regexp Cookie _oauth2_proxy
	}

	# Requests that carry authentication (session cookie or Bearer token).
	@needs_oauth {
		not header X-Api-Key *
		not path /oauth2/*
		not path /oauth/*
	}

	# ---------------------------------------------------------------------------
	# OAuth 2.0 / MCP discovery — all public, no auth required
	# ---------------------------------------------------------------------------

	# RFC 9728: per-path resource metadata so VS Code's strict resource-match passes.
	# registration_endpoint advertised here for clients that read it from resource metadata.
	handle /.well-known/oauth-protected-resource/logs/mcp {
		header Content-Type "application/json"
		respond `{"resource":"{env.MCP_BASE_URL}/logs/mcp","authorization_servers":["{env.MCP_BASE_URL}"],"bearer_methods_supported":["header"],"registration_endpoint":"{env.MCP_BASE_URL}/oauth/register"}` 200
	}

	handle /.well-known/oauth-protected-resource/quantum/mcp {
		header Content-Type "application/json"
		respond `{"resource":"{env.MCP_BASE_URL}/quantum/mcp","authorization_servers":["{env.MCP_BASE_URL}"],"bearer_methods_supported":["header"],"registration_endpoint":"{env.MCP_BASE_URL}/oauth/register"}` 200
	}

	handle /.well-known/oauth-protected-resource {
		header Content-Type "application/json"
		respond `{"resource":"{env.MCP_BASE_URL}","authorization_servers":["{env.MCP_BASE_URL}"],"bearer_methods_supported":["header"],"registration_endpoint":"{env.MCP_BASE_URL}/oauth/register"}` 200
	}

	# RFC 8414: AS metadata — Pocket ID returns 404 for this, so we serve a synthetic
	# version that mirrors Pocket ID's real endpoints and adds registration_endpoint.
	# Clients that follow authorization_servers → oauth-authorization-server will find DCR here.
	handle /.well-known/oauth-authorization-server {
		header Content-Type "application/json"
		respond `{"issuer":"{env.MCP_BASE_URL}","authorization_endpoint":"{env.POCKET_ID_URL}/authorize","token_endpoint":"{env.POCKET_ID_URL}/api/oidc/token","jwks_uri":"{env.POCKET_ID_URL}/.well-known/jwks.json","userinfo_endpoint":"{env.POCKET_ID_URL}/api/oidc/userinfo","registration_endpoint":"{env.MCP_BASE_URL}/oauth/register","response_types_supported":["code"],"grant_types_supported":["authorization_code"],"code_challenge_methods_supported":["S256"],"token_endpoint_auth_methods_supported":["none","client_secret_basic","client_secret_post"]}` 200
	}

	# RFC 7591: Dynamic Client Registration.
	# Always returns the shared mcp-tool-client ID — no new client is created in Pocket ID.
	# All MCP tools (VS Code, ChatGPT, Claude Desktop…) get this client_id automatically.
	handle /oauth/register {
		@post method POST
		handle @post {
			header Content-Type "application/json"
			respond `{"client_id":"{env.MCP_TOOL_CLIENT_ID}","client_id_issued_at":0,"client_secret_expires_at":0,"token_endpoint_auth_method":"none","grant_types":["authorization_code"],"response_types":["code"],"code_challenge_methods_supported":["S256"]}` 201
		}
		respond "Method Not Allowed" 405
	}

	# OAuth2-proxy endpoints (sign-in, callback, etc.)
	handle /oauth2/* {
		reverse_proxy oauth2-proxy:4180
	}

	# MCP clients with no auth → tell them to discover OAuth via WWW-Authenticate
	handle @mcp_unauthenticated {
		header WWW-Authenticate `Bearer resource_metadata="{env.MCP_BASE_URL}/.well-known/oauth-protected-resource"`
		respond 401
	}

	# Redirect unauthenticated browser requests to Pocket ID via oauth2-proxy
	handle @needs_login {
		redir * /oauth2/start?rd={http.request.uri} 302
	}

	# Validate session cookie or Bearer token, then proxy to MCP services
	handle @needs_oauth {
		forward_auth oauth2-proxy:4180 {
			uri /oauth2/auth
			copy_headers X-Auth-Request-User X-Auth-Request-Email X-Auth-Request-Groups
		}

		handle_path /logs/* {
			reverse_proxy management-logs-mcp:3000 {
				flush_interval -1
			}
		}

		handle_path /quantum/* {
			reverse_proxy quantum-management-mcp:3001 {
				flush_interval -1
			}
		}

		handle {
			header Content-Type "text/html; charset=utf-8"
			respond `<!doctype html><html lang="en"><head><meta charset="utf-8">
<title>Check Point MCP Proxy</title>
<style>body{font-family:sans-serif;max-width:600px;margin:2rem auto;padding:0 1rem}
h1{font-size:1.2rem}table{border-collapse:collapse;width:100%}
td,th{text-align:left;padding:.4rem .8rem;border-bottom:1px solid #ddd}
th{font-weight:600;color:#555;font-size:.85rem}
a{color:#0066cc}code{background:#f4f4f4;padding:.1rem .3rem;border-radius:3px;font-size:.9rem}</style>
</head><body>
<h1>Check Point MCP Proxy</h1>
<table>
<tr><th>Service</th><th>MCP endpoint</th><th>Health</th></tr>
<tr><td>Quantum Management</td><td><a href="/quantum/mcp"><code>/quantum/mcp</code></a></td><td><a href="/quantum/health">/quantum/health</a></td></tr>
<tr><td>Management Logs</td><td><a href="/logs/mcp"><code>/logs/mcp</code></a></td><td><a href="/logs/health">/logs/health</a></td></tr>
</table>
</body></html>` 200
		}
	}

	# API key authenticated requests — bypass OAuth entirely
	handle @has_api_key {
		handle_path /logs/* {
			reverse_proxy management-logs-mcp:3000 {
				flush_interval -1
			}
		}

		handle_path /quantum/* {
			reverse_proxy quantum-management-mcp:3001 {
				flush_interval -1
			}
		}

		handle {
			header Content-Type "text/html; charset=utf-8"
			respond `<!doctype html><html lang="en"><head><meta charset="utf-8">
<title>Check Point MCP Proxy</title>
<style>body{font-family:sans-serif;max-width:600px;margin:2rem auto;padding:0 1rem}
h1{font-size:1.2rem}table{border-collapse:collapse;width:100%}
td,th{text-align:left;padding:.4rem .8rem;border-bottom:1px solid #ddd}
th{font-weight:600;color:#555;font-size:.85rem}
a{color:#0066cc}code{background:#f4f4f4;padding:.1rem .3rem;border-radius:3px;font-size:.9rem}</style>
</head><body>
<h1>Check Point MCP Proxy</h1>
<table>
<tr><th>Service</th><th>MCP endpoint</th><th>Health</th></tr>
<tr><td>Quantum Management</td><td><a href="/quantum/mcp"><code>/quantum/mcp</code></a></td><td><a href="/quantum/health">/quantum/health</a></td></tr>
<tr><td>Management Logs</td><td><a href="/logs/mcp"><code>/logs/mcp</code></a></td><td><a href="/logs/health">/logs/health</a></td></tr>
</table>
</body></html>` 200
		}
	}

	handle {
		header Content-Type text/plain
		respond "401 Unauthorized: provide X-Api-Key header or authenticate via OAuth" 401
	}
}
